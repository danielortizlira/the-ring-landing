<header class="mb-8 text-center">
  <h1 class="text-4xl font-bold text-primary">Delete Your Account</h1>
  <p class="text-gray-500 mt-2">Permanently remove your account and all associated data</p>
</header>

<% if notice.present? %>
  <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800">
    <%= notice %>
  </div>
<% end %>

<% if alert.present? || flash[:alert].present? %>
  <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800">
    <%= alert || flash[:alert] %>
  </div>
<% end %>

<section class="mb-6">
  <p class="mb-4 text-gray-700">
    Submitting this form will send a confirmation email to the address you provide.
    You must click the link in that email to permanently delete your account.
  </p>
  <p class="mb-4 text-gray-700">The following data will be permanently deleted:</p>
  <ul class="list-disc list-inside ml-4 mb-4 text-gray-700">
    <li>Your account and login credentials</li>
    <li>All workout history and progress</li>
    <li>All training plans</li>
    <li>All personal information associated with your account</li>
  </ul>
  <p class="text-gray-600 text-sm">
    If you have questions, contact us at
    <a href="mailto:support@the-ring.app" class="text-secondary-500 hover:underline">support@the-ring.app</a>.
  </p>
</section>

<section>
  <%= form_with url: delete_account_path, method: :post, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, "Account email address", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email,
            name: "account_deletion_request[email]",
            value: @email,
            placeholder: "your@email.com",
            required: true,
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400 focus:border-red-400" %>
    </div>

    <div class="flex items-start gap-3">
      <%= f.check_box :confirm,
            name: "account_deletion_request[confirm]",
            required: true,
            class: "mt-1 h-4 w-4 text-red-600 border-gray-300 rounded" %>
      <label for="account_deletion_request_confirm" class="text-sm text-gray-700">
        I understand this action is permanent and cannot be undone. All my data will be deleted.
      </label>
    </div>

    <%= f.submit "Submit Deletion Request",
          class: "w-full bg-red-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors cursor-pointer" %>
  <% end %>
</section>

<footer class="mt-10 pt-6 border-t border-gray-300 text-center text-sm text-gray-500">
  <p>&copy; <%= Time.now.year %> TheRing. All rights reserved.</p>
</footer>
