<header class="mb-8 text-center">
  <h1 class="text-4xl font-bold text-red-600">Confirm Account Deletion</h1>
</header>

<section class="mb-8">
  <div class="p-4 bg-red-50 border border-red-200 rounded-lg mb-6">
    <p class="text-red-800 font-semibold">Warning: This action is permanent and cannot be undone.</p>
  </div>
  <p class="mb-4 text-gray-700">
    You are about to permanently delete your TheRing account and all associated data, including:
  </p>
  <ul class="list-disc list-inside ml-4 mb-6 text-gray-700">
    <li>Your account and login credentials</li>
    <li>All workout history and progress</li>
    <li>All training plans</li>
    <li>All personal information associated with your account</li>
  </ul>
  <p class="text-gray-700 mb-6">Once deleted, this data cannot be recovered.</p>

  <div class="flex flex-col sm:flex-row gap-4">
    <%= button_to "Delete My Account",
          confirm_account_deletion_path(@token),
          method: :delete,
          data: { turbo: false },
          class: "bg-red-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors cursor-pointer text-center" %>
    <%= link_to "Cancel", root_path,
          class: "bg-gray-100 text-gray-700 px-6 py-3 rounded-lg font-semibold hover:bg-gray-200 transition-colors text-center" %>
  </div>
</section>

<footer class="mt-10 pt-6 border-t border-gray-300 text-center text-sm text-gray-500">
  <p>&copy; <%= Time.now.year %> TheRing. All rights reserved.</p>
</footer>
