<header class="mb-8 text-center">
  <h1 class="text-4xl font-bold text-secondary-600">Account Deleted</h1>
</header>

<section class="mb-6 text-center">
  <div class="p-6 bg-success text-white rounded-lg mb-6">
    <p class="text-lg font-semibold mb-2">Your account has been permanently deleted.</p>
    <p>A confirmation email has been sent to you for your records.</p>
  </div>

  <p class="text-gray-700 mb-6">
    All your data — including workout history, training plans, and personal information —
    has been removed from our systems.
  </p>

  <p class="text-gray-600 mb-8">
    If you have any questions, contact us at
    <a href="mailto:<%= support_email %>" class="text-secondary-500 hover:underline"><%= support_email %></a>.
  </p>

  <%= link_to "Back to Home", root_path,
        class: "bg-primary-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary-700 transition-colors" %>
</section>
